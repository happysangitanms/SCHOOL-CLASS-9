/* Audio button states - Enhanced */
.audio-control-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 3px 10px rgba(0,0,0,0.25);
    margin-left: 10px;
    vertical-align: middle;
    opacity: 1;  /* ← ADDED */
}

.audio-control-btn:hover:not(.error):not(:disabled) {
    transform: scale(1.15);
    box-shadow: 0 5px 15px rgba(0,0,0,0.35);
}

/* Playing state - pulsing animation */
.audio-control-btn.playing {
    animation: pulse 1.5s infinite;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

/* Paused state */
.audio-control-btn.paused {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

/* Error state */
.audio-control-btn.error {
    background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
    cursor: not-allowed;
    animation: shake 0.5s;
}

/* Stopped/Ready state - subtle glow */
.audio-control-btn:not(.playing):not(.error):not(.paused) {
    box-shadow: 0 3px 10px rgba(102, 126, 234, 0.3);
}

.audio-control-btn:not(.playing):not(.error):not(.paused):hover {
    box-shadow: 0 5px 15px rgba(102, 126, 234, 0.5);
}

