/* Chalk dust texture */
.answer-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
        radial-gradient(circle at 20% 30%, rgba(255,255,255,0.05) 1px, transparent 1px),
        radial-gradient(circle at 80% 70%, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px, 60px 60px;
    pointer-events: none;
    z-index: 1;
}

/* Writing hand - CORRECTED */
.writing-hand {
    position: absolute;
    font-size: 40px;
    z-index: 100;
    pointer-events: none;
    filter: drop-shadow(3px 3px 6px rgba(0,0,0,0.5));
    will-change: transform;
    transition: none; /* Remove transition for instant movement */
}

/* Hand writing animation */
.writing-hand.writing {
    animation: handWrite 0.25s ease-in-out infinite;
}

@keyframes handWrite {
    0%, 100% { 
        transform: rotate(-2deg) translateX(0px);
    }
    50% { 
        transform: rotate(2deg) translateX(3px);
    }
}

/* Chalk piece */
.chalk-piece {
    position: absolute;
    width: 5px;
    height: 16px;
    background: linear-gradient(180deg, #ffffff 0%, #f0f0f0 100%);
    border-radius: 2px;
    box-shadow: 1px 1px 3px rgba(0,0,0,0.3);
    z-index: 101;
    pointer-events: none;
    will-change: transform;
    transition: none;
}

/* Chalk dust particles */
.chalk-dust {
    position: absolute;
    width: 3px;
    height: 3px;
    background: rgba(255,255,255,0.7);
    border-radius: 50%;
    pointer-events: none;
    z-index: 50;
    animation: dustFall 0.6s ease-out forwards;
}

@keyframes dustFall {
    0% { 
        opacity: 0.8;
        transform: translateY(0) translateX(0) scale(1);
    }
    100% { 
        opacity: 0;
        transform: translateY(25px) translateX(10px) scale(0.3);
    }
}

