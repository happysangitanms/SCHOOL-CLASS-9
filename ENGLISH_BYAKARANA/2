}

// Validate audio URL
function isValidAudioUrl(url) {
    if (!url) return false;
    if (url.includes('example.com')) return false;
    if (url.includes('YOUR_USERNAME')) return false;
    if (url.includes('YOUR_REPO')) return false;
    if (!url.startsWith('http')) return false;
    return true;
}

    
