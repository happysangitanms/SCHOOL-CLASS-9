        /* Dropdown Styles */
        .assistant-dropdown-wrapper {
            max-width: 600px;
            margin: 0 auto 20px;
            position: relative;
        }

        .assistant-dropdown-btn {
            width: 100%;
            padding: 18px 24px;
            background: white;
            border: 3px solid #667eea;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 600;
            color: #333;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .assistant-dropdown-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.3);
        }

        .assistant-dropdown-btn.active {
            border-color: #764ba2;
            background: #f8f9ff;
        }

        .dropdown-icon {
            font-size: 28px;
        }

        .dropdown-text {
            flex: 1;
            text-align: left;
            color: #555;
        }

        .dropdown-arrow {
            font-size: 14px;
            transition: transform 0.3s ease;
        }

        .assistant-dropdown-btn.active .dropdown-arrow {
            transform: rotate(180deg);
        }

        .assistant-dropdown-menu {
            position: absolute;
            bottom: calc(100% + 10px);
            left: 0;
            right: 0;
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
            max-height: 400px;
            overflow-y: auto;
        }

        .assistant-dropdown-menu.active {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-item {
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 1px solid #f0f0f0;
        }

        .dropdown-item:last-child {
            border-bottom: none;
        }

        .dropdown-item:hover {
            background: linear-gradient(90deg, #f0f4ff 0%, #fef0ff 100%);
            transform: translateX(5px);
        }

        .item-icon {
            font-size: 32px;
